{
  "name": "ecmascript-parser-benchmark-js",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "bench": "node scripts/load-files.ts && node scripts/bench.ts && pnpm run readme",
    "bench:typescript": "node scripts/bench.ts typescript",
    "bench:checker": "node scripts/bench.ts checker",
    "bench:react": "node scripts/bench.ts react",
    "readme": "node scripts/generate-readme.ts",
    "update-parsers": "pnpm update --latest",
    "type-check": "tsgo --noEmit"
  },
  "dependencies": {
    "@babel/parser": "^8.0.0",
    "@swc/core": "^1.15.43",
    "acorn": "^8.17.0",
    "chart.js": "^4.5.1",
    "chartjs-node-canvas": "^5.0.0",
    "oxc-parser": "^0.137.0",
    "tinybench": "^6.0.2",
    "yuku-parser": "^0.7.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260624.1"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@swc/core", "canvas"]
  }
}
